# Frontend Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Vercel Web Analytics API (server-only; never prefix the access token with VITE_)
VERCEL_ANALYTICS_ACCESS_TOKEN=your_dedicated_vercel_access_token
VERCEL_ANALYTICS_PROJECT_ID=prj_xxx
VERCEL_ANALYTICS_TEAM_ID=team_xxx

# Radio stream (Icecast/SHOUTcast/HLS)
VITE_RADIO_STREAM_URL=https://ice1.somafm.com/groovesalad-256-mp3
VITE_RADIO_STREAM_HIGH=
VITE_RADIO_STREAM_LOW=

# Now playing / AzuraCast
VITE_AZURACAST_API=
VITE_AZURACAST_STATION=

# Web Push frontend
VITE_VAPID_PUBLIC_KEY=

# Public app URL used by emails, push notifications and callbacks
APP_URL=https://www.polyfauna.com

# Supabase Edge Functions
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Wompi
WOMPI_PUBLIC_KEY=pub_test_xxx
WOMPI_INTEGRITY_KEY=integrity_xxx
WOMPI_EVENTS_KEY=events_xxx

# Email
RESEND_API_KEY=re_xxx
RESEND_WEBHOOK_SECRET=whsec_xxx
SUPPORT_EMAIL=info@polyfauna.com
EMAIL_UNSUBSCRIBE_URL=https://www.polyfauna.com/unsubscribe

# Ticket QR signing (private JWK for Edge Functions; public JWK lives in src/lib/ticketSigningKey.js)
TICKET_QR_PRIVATE_JWK='{"kty":"EC","crv":"P-256","d":"...","x":"...","y":"..."}'

# Web Push Edge Function
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# R2 uploads
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=
